# Supabase — copy this file to .env.local and fill in real values.
# .env.local is gitignored (via `.env*` + `!.env.example`); NEVER commit real secrets.
# NEXT_PUBLIC_* is inlined into the browser bundle by Next → only browser-safe values here.

# Project URL (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (sb_publishable_...) — replaces the legacy anon key.
# Low-privilege, RLS-gated, safe in the browser bundle.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (sb_secret_...) — replaces the legacy service_role key.
# SERVER-ONLY. Elevated privileges, bypasses RLS. NO NEXT_PUBLIC_ prefix so Next never
# inlines it into the client bundle. Used only in Route Handlers / RSC / Server Actions.
SUPABASE_SECRET_KEY=

# Tooling only — used by `pnpm gen:db-types` / migration CLI against the hosted project.
# Not read at runtime. Find it in the project URL: https://<PROJECT_REF>.supabase.co
SUPABASE_PROJECT_REF=
